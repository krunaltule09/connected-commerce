{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://experiencecenter.ey.com/**" },
        { "url": "https://experiencecenter.ey.com:1337/**" },
        { "url": "http://127.0.0.1:8000/**" },
        { "url": "https://sse-service-lnsk.onrender.com/**" }
      ]
    }
  ]
}
