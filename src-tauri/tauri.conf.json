{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BCM Operate",
  "version": "0.1.0",
  "identifier": "com.ey.bcmoperate",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BCM Operate",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http: https:; media-src 'self' asset: blob: http: https:; font-src 'self' data:; connect-src 'self' ws: wss: http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
